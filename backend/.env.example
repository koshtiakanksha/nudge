# =========================================
# NUDGE BACKEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Anything left blank falls back to MOCK MODE for that integration
# (see app/core/config.py) so the app runs locally without every key.
# =========================================

# --- App ---
ENVIRONMENT=development            # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# --- Supabase / Postgres ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (Supabase gives you this under Project Settings > Database)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nudge
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nudge

# --- JWT (Supabase Auth) ---
SUPABASE_JWT_SECRET=

# --- Encryption for Plaid access tokens at rest ---
TOKEN_ENCRYPTION_KEY=               # 32-byte urlsafe base64 Fernet key, generate with scripts/gen_key.py

# --- Plaid ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                   # sandbox | development | production
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# --- Redis (Upstash or local) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Price Intelligence ---
CAMELCAMELCAMEL_API_KEY=
SCRAPER_USER_AGENT=Mozilla/5.0 (NudgeBot/1.0)

# --- Local Deals ---
GOOGLE_PLACES_API_KEY=
YELP_FUSION_API_KEY=
FLIPP_API_KEY=
EVENTBRITE_API_TOKEN=

# --- Inflation / Benchmarking ---
BLS_API_KEY=

# --- Investments (optional, non-MVP) ---
ALPHA_VANTAGE_API_KEY=

# --- Email (weekly pulse, alerts) ---
SENDGRID_API_KEY=
EMAIL_FROM=nudge@yourdomain.com

# --- Web Push ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Monitoring ---
SENTRY_DSN=
